TAURUS_ENV=local
TAURUS_MODE=paper
LIVE_TRADING_ENABLED=false
DATABASE_URL=postgresql+psycopg://taurus:taurus@localhost:5432/taurus
TAURUS_UNIVERSE=NIFTY_100
TAURUS_TIMEFRAME=1d
TAURUS_MARKET_DATA_PROVIDER=mock
TAURUS_PRICE_CSV_PATH=
TAURUS_PRICE_CSV_DIR=
TAURUS_MOCK_SEED=42
TAURUS_MOCK_CANDLE_COUNT=252
TAURUS_INITIAL_CAPITAL_INR=1000000
TAURUS_MAX_POSITION_PCT=5
TAURUS_MAX_OPEN_POSITIONS=8
TAURUS_KILL_SWITCH_ENABLED=false
TAURUS_MAX_DAILY_LOSS_PCT=3.0
TAURUS_PAPER_SLIPPAGE_BPS=5.0
TAURUS_PAPER_BROKERAGE_BPS=3.0
TAURUS_PAPER_EXCHANGE_TXN_CHARGE_BPS=0.35
TAURUS_PAPER_TAX_LEVY_BPS=1.0
TAURUS_PAPER_PARTIAL_FILL_THRESHOLD=50
TAURUS_PAPER_FIRST_FILL_PCT=0.60
TAURUS_PAPER_TIMEZONE=Asia/Kolkata
TAURUS_PAPER_AFTER_MARKET_CLOSE=true
TAURUS_PAPER_SCHEDULE=daily_after_close
TAURUS_LLM_PROVIDER=mock
TAURUS_LLM_BASE_URL=
TAURUS_ALERT_PROVIDER=mock
# Default keeps all current analysts. Use technical,news,sentiment to skip fundamentals
# until imported fundamental data is available, or technical for technical-only paper runs.
# Available analysts: technical, news, sentiment, fundamentals
TAURUS_ENABLED_ANALYSTS=technical,news,sentiment,fundamentals
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BROKER_PROVIDER=paper
